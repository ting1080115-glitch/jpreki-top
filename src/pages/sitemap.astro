---
const fs = await import('fs');
const postsDir = './content/posts';
const posts = [];
if (fs.existsSync(postsDir)) {
  const files = fs.readdirSync(postsDir).filter(f => f.endsWith('.md'));
  for (const file of files) {
    const slug = file.replace('.md', '');
    const content = fs.readFileSync(postsDir + '/' + file, 'utf-8');
    const mDate = content.match(/^date:\s*(\d{4}-\d{2}-\d{2})/m);
    posts.push({ slug, date: mDate ? mDate[1] : '2026-07-14' });
  }
}
const today = '2026-07-14';
---
<?xml version="1.0" encoding="UTF-8"?>
<urlset xmlns="http://www.sitemaps.org/schemas/sitemap/0.9">
  <url><loc>https://jpreki.top/</loc><lastmod>{today}</lastmod><changefreq>weekly</changefreq><priority>1.0</priority></url>
  <url><loc>https://jpreki.top/jpantao-rec</loc><lastmod>{today}</lastmod><changefreq>monthly</changefreq><priority>0.8</priority></url>
  <url><loc>https://jpreki.top/donaa-rec</loc><lastmod>{today}</lastmod><changefreq>monthly</changefreq><priority>0.8</priority></url>
  <url><loc>https://jpreki.top/jpchurec</loc><lastmod>{today}</lastmod><changefreq>monthly</changefreq><priority>0.8</priority></url>
  <url><loc>https://jpreki.top/777dairec</loc><lastmod>{today}</lastmod><changefreq>monthly</changefreq><priority>0.8</priority></url>
  <url><loc>https://jpreki.top/77jpchurec</loc><lastmod>{today}</lastmod><changefreq>monthly</changefreq><priority>0.8</priority></url>
  <url><loc>https://jpreki.top/blog/</loc><lastmod>{today}</lastmod><changefreq>daily</changefreq><priority>0.9</priority></url>
  {posts.map(p => <url><loc>https://jpreki.top/blog/{encodeURIComponent(p.slug)}</loc><lastmod>{p.date}</lastmod><changefreq>monthly</changefreq><priority>0.7</priority></url>)}
</urlset>